generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  SUPER_ADMIN
  SENIOR_ADMIN
  ADMIN
}

enum BranchType {
  MAIN
  BRANCH
}

enum StockTone {
  NORMAL
  LOW
  CRITICAL
}

enum TransferStatus {
  PENDING
  IN_TRANSIT
  COMPLETED
  CANCELLED
}

enum OrderStatus {
  DRAFT
  CONFIRMED
  PROCESSING
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  UNPAID
  PARTIAL
  PAID
  REFUNDED
}

enum PaymentMethod {
  CASH
  ONLINE
  CANARA_UPI
  BOB_UPI
  UPI_BHARATH
  UPI_POORNIMA
  CARD
  CHEQUE
  BANK_TRANSFER
  GPAY
  PHONEPE
  PAYTM
  CREDIT
  OTHER
}

enum ItemType {
  BOOK
  UNIFORM
  ACCESSORY
}

enum LogChangeType {
  INCOMING
  OUTGOING
  ADJUSTMENT
  TRANSFER_IN
  TRANSFER_OUT
  PROCUREMENT
  DISTRIBUTION
}

enum ProductType {
  SET
  INDIVIDUAL
  VARIANT
}

/// Academic textbooks/workbooks kit vs dedicated notebook bundle kit (same grade, separate `BookKit` rows).
enum BookKitKind {
  ACADEMIC
  NOTEBOOKS
}

enum BookStatus {
  TAKEN
  PARTIAL
  NOT_TAKEN
}

enum UniformStatus {
  COMPLETE
  PARTIAL
  PENDING
}

enum ExpenseEntryType {
  HANDOVER
  EXPENSE
  ONLINE_ALLOCATION
}

enum ExpenseCategory {
  STATIONERY
  MAINTENANCE
  FOOD
  TRANSPORT
  MISCELLANEOUS
}

// ─── Users & Auth ─────────────────────────────────────────────────────────────

model User {
  id                 String    @id @default(cuid())
  username           String    @unique
  email              String    @unique
  passwordHash       String
  displayName        String
  role               Role
  permissions        Json?
  mustChangePassword Boolean   @default(false)
  lastLoginAt        DateTime?
  isActive           Boolean   @default(true)
  branchId           String?
  branch             Branch?   @relation(fields: [branchId], references: [id])
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  orders                         Order[]                @relation("OrderCreatedBy")
  stockTransfers                 StockTransfer[]        @relation("TransferBy")
  inventoryLogs                  InventoryLog[]         @relation("LogPerformedBy")
  refreshTokens                  RefreshToken[]
  admissionsCreated              AdmissionStudent[]     @relation("AdmissionCreatedBy")
  admissionTransactionsProcessed AdmissionTransaction[] @relation("AdmissionTransactionBy")
  expenseEntriesCreated          ExpenseEntry[]         @relation("ExpenseEntryCreatedBy")
  expenseEntriesApproved         ExpenseEntry[]         @relation("ExpenseEntryApprovedBy")
  onlineSettlementsRecorded      OnlineSettlement[]     @relation("OnlineSettlementSettledBy")
  transactionGroups              TransactionGroup[]     @relation("TransactionGroupCreatedBy")

  @@index([role])
  @@index([branchId])
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

// ─── Branch / Campus ──────────────────────────────────────────────────────────

model Branch {
  id        String     @id @default(cuid())
  name      String
  code      String     @unique
  type      BranchType @default(BRANCH)
  address   String?
  phone     String?
  email     String?
  isActive  Boolean    @default(true)
  deletedAt DateTime?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  users                 User[]
  academicClasses       AcademicClass[]
  bookStocks            BookStock[]
  uniformStocks         UniformStock[]
  accessoryStocks       AccessoryStock[]
  stockTransfersFrom    StockTransfer[]        @relation("TransferFrom")
  stockTransfersTo      StockTransfer[]        @relation("TransferTo")
  orders                Order[]
  transactions          Transaction[]
  inventoryLogs         InventoryLog[]
  procurements          ProcurementEntry[]
  admissionStudents     AdmissionStudent[]
  admissionTransactions AdmissionTransaction[]
  expenseEntries        ExpenseEntry[]         @relation("BranchExpenseEntries")
  expenseRecipients     ExpenseRecipient[]     @relation("BranchExpenseRecipients")
  onlineSettlements     OnlineSettlement[]     @relation("BranchOnlineSettlements")
  transactionGroups     TransactionGroup[]     @relation("BranchTransactionGroups")

  @@index([type])
  @@index([isActive])
  @@index([deletedAt])
}

/// UI / API reference data (payment methods, filter labels, etc.) — single source of truth vs inline constants.
model ReferenceOption {
  id        String   @id @default(cuid())
  category  String
  code      String
  label     String
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([category, code])
  @@index([category, isActive])
}

// ─── Academic Structure ───────────────────────────────────────────────────────

model AcademicClass {
  id           String   @id @default(cuid())
  grade        Int
  section      String
  label        String
  studentCount Int      @default(0)
  branchId     String
  branch       Branch   @relation(fields: [branchId], references: [id])
  academicYear String   @default("2024-25")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  students Students[]
  bookKits BookKit[]

  @@unique([grade, section, branchId, academicYear])
  @@index([branchId])
  @@index([grade])
}

model Students {
  id            String        @id @default(cuid())
  name          String
  rollNumber    String
  initials      String
  guardianName  String?
  guardianPhone String?
  photoUrl      String?
  classId       String
  class         AcademicClass @relation(fields: [classId], references: [id])
  isActive      Boolean       @default(true)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  orders     Order[]
  orderItems OrderItem[]

  @@unique([rollNumber, classId])
  @@index([classId])
}

// ─── Books Inventory ──────────────────────────────────────────────────────────

model BookKit {
  id          String        @id @default(cuid())
  kind        BookKitKind   @default(ACADEMIC)
  label       String
  badge       String?
  classId     String
  class       AcademicClass @relation(fields: [classId], references: [id], onDelete: Cascade)
  lastUpdated DateTime      @default(now())
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  items BookKitItem[]

  @@unique([classId, kind])
  @@index([classId])
}

model BookKitItem {
  id          String      @id @default(cuid())
  kitId       String
  kit         BookKit     @relation(fields: [kitId], references: [id], onDelete: Cascade)
  catalogKey  String?
  label       String
  icon        String      @default("menu_book")
  price       Decimal     @db.Decimal(10, 2)
  setPrice    Decimal?    @db.Decimal(10, 2)
  productType ProductType @default(INDIVIDUAL)
  position    Int         @default(0)
  isArchived  Boolean     @default(false)

  subItems           BookKitSubItem[]
  bookStocks         BookStock[]
  stockTransferItems StockTransferItem[]
  orderItems         OrderItem[]
  inventoryLogs      InventoryLog[]
  procurements       ProcurementEntry[]

  @@index([kitId])
  @@index([catalogKey])
}

model BookKitSubItem {
  id        String      @id @default(cuid())
  kitItemId String
  kitItem   BookKitItem @relation(fields: [kitItemId], references: [id], onDelete: Cascade)
  label     String
  price     Decimal     @db.Decimal(10, 2)
  quantity  Int         @default(0)
  position  Int         @default(0)
  isActive  Boolean     @default(true)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@index([kitItemId])
}

model BookStock {
  id        String      @id @default(cuid())
  itemId    String
  item      BookKitItem @relation(fields: [itemId], references: [id])
  branchId  String
  branch    Branch      @relation(fields: [branchId], references: [id])
  quantity  Int         @default(0)
  reserved  Int         @default(0)
  tone      StockTone   @default(NORMAL)
  updatedAt DateTime    @updatedAt
  createdAt DateTime    @default(now())

  @@unique([itemId, branchId])
  @@index([branchId])
  @@index([itemId])
}

// ─── Uniforms Inventory ───────────────────────────────────────────────────────

model UniformCategory {
  id        String   @id @default(cuid())
  name      String   @unique
  label     String
  icon      String
  position  Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  sizes UniformSize[]
}

model UniformSize {
  id               String          @id @default(cuid())
  categoryId       String
  category         UniformCategory @relation(fields: [categoryId], references: [id])
  code             String
  name             String
  price            Decimal         @db.Decimal(10, 2)
  reorderThreshold Int             @default(50)
  position         Int             @default(0)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  uniformStocks      UniformStock[]
  stockTransferItems StockTransferItem[]
  orderItems         OrderItem[]
  inventoryLogs      InventoryLog[]

  @@unique([categoryId, code])
  @@index([categoryId])
}

model UniformStock {
  id        String      @id @default(cuid())
  sizeId    String
  size      UniformSize @relation(fields: [sizeId], references: [id])
  branchId  String
  branch    Branch      @relation(fields: [branchId], references: [id])
  quantity  Int         @default(0)
  reserved  Int         @default(0)
  tone      StockTone   @default(NORMAL)
  updatedAt DateTime    @updatedAt
  createdAt DateTime    @default(now())

  @@unique([sizeId, branchId])
  @@index([branchId])
  @@index([sizeId])
}

// ─── Accessories Inventory ────────────────────────────────────────────────────

model AccessoryGroup {
  id        String   @id @default(cuid())
  name      String   @unique
  label     String
  icon      String
  position  Int      @default(0)
  createdAt DateTime @default(now())

  accessories Accessory[]
}

model Accessory {
  id        String         @id @default(cuid())
  groupId   String
  group     AccessoryGroup @relation(fields: [groupId], references: [id])
  sku       String         @unique
  name      String
  label     String
  icon      String         @default("category")
  price     Decimal        @db.Decimal(10, 2)
  isActive  Boolean        @default(true)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  accessoryStocks    AccessoryStock[]
  stockTransferItems StockTransferItem[]
  orderItems         OrderItem[]
  inventoryLogs      InventoryLog[]

  @@index([groupId])
}

model AccessoryStock {
  id          String    @id @default(cuid())
  accessoryId String
  accessory   Accessory @relation(fields: [accessoryId], references: [id])
  branchId    String
  branch      Branch    @relation(fields: [branchId], references: [id])
  quantity    Int       @default(0)
  reserved    Int       @default(0)
  tone        StockTone @default(NORMAL)
  updatedAt   DateTime  @updatedAt
  createdAt   DateTime  @default(now())

  @@unique([accessoryId, branchId])
  @@index([branchId])
  @@index([accessoryId])
}

// ─── Stock Transfers (Main → Branch) ─────────────────────────────────────────

model StockTransfer {
  id              String         @id @default(cuid())
  referenceId     String         @unique @default(cuid())
  fromBranchId    String
  fromBranch      Branch         @relation("TransferFrom", fields: [fromBranchId], references: [id])
  toBranchId      String
  toBranch        Branch         @relation("TransferTo", fields: [toBranchId], references: [id])
  transferredById String
  transferredBy   User           @relation("TransferBy", fields: [transferredById], references: [id])
  status          TransferStatus @default(PENDING)
  notes           String?
  completedAt     DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  items StockTransferItem[]

  @@index([fromBranchId])
  @@index([toBranchId])
  @@index([status])
}

model StockTransferItem {
  id            String        @id @default(cuid())
  transferId    String
  transfer      StockTransfer @relation(fields: [transferId], references: [id], onDelete: Cascade)
  itemType      ItemType
  bookItemId    String?
  bookItem      BookKitItem?  @relation(fields: [bookItemId], references: [id])
  uniformSizeId String?
  uniformSize   UniformSize?  @relation(fields: [uniformSizeId], references: [id])
  accessoryId   String?
  accessory     Accessory?    @relation(fields: [accessoryId], references: [id])
  quantity      Int
  createdAt     DateTime      @default(now())

  @@index([transferId])
}

// ─── Orders ───────────────────────────────────────────────────────────────────

model Order {
  id                String         @id @default(cuid())
  orderId           String         @unique
  studentId         String
  student           Students       @relation(fields: [studentId], references: [id])
  branchId          String
  branch            Branch         @relation(fields: [branchId], references: [id])
  createdById       String
  createdBy         User           @relation("OrderCreatedBy", fields: [createdById], references: [id])
  status            OrderStatus    @default(DRAFT)
  paymentStatus     PaymentStatus  @default(UNPAID)
  paymentMethod     PaymentMethod?
  bookStatus        BookStatus     @default(NOT_TAKEN)
  uniformStatus     UniformStatus  @default(PENDING)
  subtotal          Decimal        @default(0) @db.Decimal(10, 2)
  administrativeFee Decimal        @default(5) @db.Decimal(10, 2)
  vatRate           Decimal        @default(0) @db.Decimal(5, 4)
  vatAmount         Decimal        @default(0) @db.Decimal(10, 2)
  total             Decimal        @default(0) @db.Decimal(10, 2)
  paidAmount        Decimal        @default(0) @db.Decimal(10, 2)
  referenceId       String?
  notes             String?
  paidAt            DateTime?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  items        OrderItem[]
  transactions Transaction[]

  transactionGroupId String?
  transactionGroup   TransactionGroup? @relation(fields: [transactionGroupId], references: [id])

  @@index([branchId])
  @@index([studentId])
  @@index([paymentStatus])
  @@index([status])
  @@index([createdAt])
  @@index([transactionGroupId])
}

model OrderItem {
  id            String       @id @default(cuid())
  orderId       String
  order         Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  studentId     String?
  student       Students?    @relation(fields: [studentId], references: [id])
  itemType      ItemType
  bookItemId    String?
  bookItem      BookKitItem? @relation(fields: [bookItemId], references: [id])
  uniformSizeId String?
  uniformSize   UniformSize? @relation(fields: [uniformSizeId], references: [id])
  accessoryId   String?
  accessory     Accessory?   @relation(fields: [accessoryId], references: [id])
  label         String
  quantity      Int          @default(1)
  unitPrice     Decimal      @db.Decimal(10, 2)
  totalPrice    Decimal      @db.Decimal(10, 2)
  createdAt     DateTime     @default(now())

  @@index([orderId])
}

// ─── Transactions ─────────────────────────────────────────────────────────────

model Transaction {
  id            String        @id @default(cuid())
  orderId       String
  order         Order         @relation(fields: [orderId], references: [id])
  branchId      String
  branch        Branch        @relation(fields: [branchId], references: [id])
  amount        Decimal       @db.Decimal(10, 2)
  paymentMethod PaymentMethod
  status        PaymentStatus
  referenceId   String?
  notes         String?
  paidAt        DateTime      @default(now())
  createdAt     DateTime      @default(now())

  @@index([branchId])
  @@index([orderId])
  @@index([status])
  @@index([paidAt])
}

// ─── Transaction Groups (multi-student combined payments) ─────────────────────

model TransactionGroup {
  id           String   @id @default(cuid())
  groupRef     String   @unique
  branchId     String
  branch       Branch   @relation("BranchTransactionGroups", fields: [branchId], references: [id])
  createdById  String
  createdBy    User     @relation("TransactionGroupCreatedBy", fields: [createdById], references: [id])
  totalAmount  Decimal  @db.Decimal(10, 2)
  splitDetails Json?
  paidAt       DateTime @default(now())
  createdAt    DateTime @default(now())

  orders Order[]

  @@index([branchId])
  @@index([createdAt])
}

// ─── New Admissions (standalone module — no relation to Orders/Transactions) ─

enum AdmissionPaymentStatus {
  PENDING
  PAID
}

enum AdmissionPaymentMethod {
  CASH
  ONLINE
  CANARA_UPI
  UPI
  CARD
  SPLIT
}

model AdmissionStudent {
  id            String                 @id @default(cuid())
  admissionCode String                 @unique
  studentName   String
  parentName    String?
  phone         String
  grade         Int
  section       String
  classLabel    String
  branchId      String
  branch        Branch                 @relation(fields: [branchId], references: [id])
  amount        Decimal                @db.Decimal(10, 2)
  remarks       String?
  paymentStatus AdmissionPaymentStatus @default(PENDING)
  createdById   String
  createdBy     User                   @relation("AdmissionCreatedBy", fields: [createdById], references: [id])
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt

  transactions AdmissionTransaction[]

  @@index([branchId])
  @@index([paymentStatus])
  @@index([grade, section])
  @@index([createdAt])
}

model AdmissionTransaction {
  id            String                 @id @default(cuid())
  admissionId   String
  admission     AdmissionStudent       @relation(fields: [admissionId], references: [id])
  branchId      String
  branch        Branch                 @relation(fields: [branchId], references: [id])
  amount        Decimal                @db.Decimal(10, 2)
  paymentMethod AdmissionPaymentMethod
  splitDetails  Json?
  remarks       String?
  processedById String
  processedBy   User                   @relation("AdmissionTransactionBy", fields: [processedById], references: [id])
  paidAt        DateTime               @default(now())
  createdAt     DateTime               @default(now())

  @@index([branchId])
  @@index([admissionId])
  @@index([paidAt])
}

model AdmissionSettings {
  id            String   @id @default(cuid())
  branchId      String?  @unique
  defaultAmount Decimal  @default(500) @db.Decimal(10, 2)
  updatedAt     DateTime @updatedAt
}

// ─── Inventory Audit Log ──────────────────────────────────────────────────────

model InventoryLog {
  id             String        @id @default(cuid())
  branchId       String
  branch         Branch        @relation(fields: [branchId], references: [id])
  itemType       ItemType
  bookItemId     String?
  bookItem       BookKitItem?  @relation(fields: [bookItemId], references: [id])
  uniformSizeId  String?
  uniformSize    UniformSize?  @relation(fields: [uniformSizeId], references: [id])
  accessoryId    String?
  accessory      Accessory?    @relation(fields: [accessoryId], references: [id])
  changeType     LogChangeType
  quantityBefore Int
  quantityAfter  Int
  quantityDelta  Int
  performedById  String
  performedBy    User          @relation("LogPerformedBy", fields: [performedById], references: [id])
  notes          String?
  createdAt      DateTime      @default(now())

  @@index([branchId])
  @@index([itemType])
  @@index([createdAt])
}

// ─── Publisher Accounts ───────────────────────────────────────────────────────

model Publisher {
  id            String   @id @default(cuid())
  name          String
  contactPerson String?
  phone         String?
  email         String?
  address       String?
  notes         String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  procurements ProcurementEntry[]
  payments     PublisherPayment[]

  @@index([isActive])
}

model ProcurementEntry {
  id                 String         @id @default(cuid())
  publisherId        String
  publisher          Publisher      @relation(fields: [publisherId], references: [id])
  branchId           String?
  branch             Branch?        @relation(fields: [branchId], references: [id])
  date               DateTime
  bookItemId         String?
  bookItem           BookKitItem?   @relation(fields: [bookItemId], references: [id])
  productLabel       String
  quantity           Int
  /// Per-branch quantities keyed by branch id (canonical); legacy columns below kept for compatibility.
  branchDistribution Json?
  qtyDarga           Int            @default(0)
  qtyNarsingi        Int            @default(0)
  qtySheikpet        Int            @default(0)
  ratePerUnit        Decimal        @db.Decimal(10, 2)
  totalAmount        Decimal        @db.Decimal(10, 2)
  paymentMethod      PaymentMethod?
  amountPaid         Decimal        @default(0) @db.Decimal(10, 2)
  notes              String?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  @@index([publisherId])
  @@index([branchId])
  @@index([date])
}

model PublisherPayment {
  id            String        @id @default(cuid())
  publisherId   String
  publisher     Publisher     @relation(fields: [publisherId], references: [id])
  date          DateTime
  amount        Decimal       @db.Decimal(10, 2)
  paymentMethod PaymentMethod
  referenceId   String?
  notes         String?
  createdAt     DateTime      @default(now())

  @@index([publisherId])
  @@index([date])
}

// ─── Expense & Cash Management ──────────────────────────────────────────────

model ExpenseEntry {
  id            String           @id @default(cuid())
  branchId      String
  branch        Branch           @relation("BranchExpenseEntries", fields: [branchId], references: [id])
  entryType     ExpenseEntryType
  amount        Decimal          @db.Decimal(10, 2)
  paymentMethod PaymentMethod
  recipient     String?
  category      ExpenseCategory?
  description   String?
  referenceId   String?
  notes         String?
  entryDate     DateTime
  status        String           @default("APPROVED")
  approvedById  String?
  approvedBy    User?            @relation("ExpenseEntryApprovedBy", fields: [approvedById], references: [id])
  approvedAt    DateTime?
  createdById   String
  createdBy     User             @relation("ExpenseEntryCreatedBy", fields: [createdById], references: [id])
  createdAt     DateTime         @default(now())

  @@index([branchId])
  @@index([entryType])
  @@index([entryDate])
  @@index([status])
  @@index([branchId, entryDate])
}

model ExpenseRecipient {
  id        String   @id @default(cuid())
  branchId  String?
  branch    Branch?  @relation("BranchExpenseRecipients", fields: [branchId], references: [id])
  name      String
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  @@index([branchId])
  @@index([isActive])
}

model OnlineSettlement {
  id             String        @id @default(cuid())
  branchId       String
  branch         Branch        @relation("BranchOnlineSettlements", fields: [branchId], references: [id])
  paymentMethod  PaymentMethod
  amountSettled  Decimal       @db.Decimal(10, 2)
  settlementDate DateTime
  utrNumber      String?
  notes          String?
  settledById    String
  settledBy      User          @relation("OnlineSettlementSettledBy", fields: [settledById], references: [id])
  createdAt      DateTime      @default(now())

  @@index([branchId])
  @@index([paymentMethod])
  @@index([settlementDate])
  @@index([branchId, paymentMethod])
}
