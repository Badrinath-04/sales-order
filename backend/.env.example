# Use a direct Postgres URL (session mode) for this long-running API — not a transaction pooler
# (e.g. avoid Supabase :6543 / "pooler" for Prisma; use :5432 or "direct connection" URL).
# Tuning: ?sslmode=require&connect_timeout=15
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"
JWT_SECRET="change-me-to-a-secure-random-string-min-32-chars"
JWT_EXPIRES_IN="7d"
PORT=4000
# Listen on all interfaces so phones/tablets on the same Wi‑Fi can reach the API
HOST=0.0.0.0
NODE_ENV=development
# Comma-separated exact origins; LAN IPs (192.168.x.x, etc.) are auto-allowed in development
CORS_ORIGIN="http://localhost:5173,http://localhost:5174,http://localhost:4173"
